# ============================================================
# photoforge configuration
# ============================================================
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git — it is already in `.gitignore`.

# ------------------------------------------------------------
# Cloudinary (image history / gallery uploads)
# ------------------------------------------------------------
# Sign up for a free account at https://cloudinary.com
# Find these values in the Cloudinary console under "Dashboard":
#   - Cloud name    -> Account Details / Cloud Name
#   - API Key       -> Account Details / API Key
#   - API Secret    -> Account Details / API Secret
#
# Notes:
#   * These stay on the server. The browser only ever talks to
#     the local proxy endpoints `/cloudinary/upload` and
#     `/cloudinary/history`, which keep the API secret off the
#     wire.
#   * Rotation: if these leak, regenerate them in the Cloudinary
#     console — you do NOT need to change anything in this repo.

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ------------------------------------------------------------
# MiniMax (cloud image generation)
# ------------------------------------------------------------
# Required for the "MiniMax" image generation backend.
# Get one at https://platform.minimax.io/user-center/basic-information/interface-key
#
# If left empty here, the server will auto-load it from
# ~/.hermes/skills/minimax-speech/.env on startup.

MINIMAX_API_KEY=your_minimax_key_here